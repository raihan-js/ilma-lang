# Test: bag methods - add, remove, size, sorted
remember fruits = bag["mango", "apple", "dates"]
say "Size: " + fruits.size

# Add an item
fruits.add("pomegranate")
say "After add: " + fruits.size

# Iterate
for each fruit in fruits:
    say fruit

# Remove an item
fruits.remove("apple")
say "After remove: " + fruits.size

# Sorted
remember numbers = bag[3, 1, 4, 1, 5, 9, 2]
remember sorted_nums = numbers.sorted()
for each n in sorted_nums:
    say n
