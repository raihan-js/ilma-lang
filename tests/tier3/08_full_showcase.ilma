# ILMA Phase 2 Milestone — Full Language Showcase
# Tests all three tiers working together

# Tier 1: say, remember, if, repeat
say "=== Tier 1: Basics ==="
remember language = "ILMA"
say language + " is amazing!"

repeat 3:
    say "SubhanAllah"

if language is "ILMA":
    say "Yes, this is ILMA!"
otherwise:
    say "Something else"

# Tier 2: recipes, bags, notebooks, while loops, text methods
say "=== Tier 2: Recipes & Collections ==="

recipe factorial(n):
    if n <= 1:
        give back 1
    give back n * factorial(n - 1)

say "5! = " + factorial(5)

remember fruits = bag["dates", "mango", "pomegranate"]
fruits.add("fig")

remember sorted_fruits = fruits.sorted()
for each fruit in sorted_fruits:
    say "  " + fruit

say "Count: " + fruits.size

remember info = notebook[name: "ILMA", version: 2, tier: "all"]
say info[name] + " v" + info[version]

remember counter = 10
keep going while counter > 0:
    counter = counter - 3

say "Counter: " + counter

# Tier 2: text methods
remember greeting = "Bismillah Al Rahman Al Rahim"
say greeting.upper()
say "Length: " + greeting.length

# Tier 2: error handling
try:
    shout "Test error"
when wrong:
    say "Error caught gracefully"

# Tier 3: blueprints with inheritance
say "=== Tier 3: Blueprints ==="

blueprint Vehicle:

    create(make, year):
        me.make = make
        me.year = year
        me.km = 0

    recipe drive(distance):
        me.km = me.km + distance

    recipe info():
        say me.make + " (" + me.year + ") - " + me.km + " km"

blueprint ElectricCar comes from Vehicle:

    create(make, year, battery):
        comes_from.create(make, year)
        me.battery = battery

    recipe charge():
        say "Charging " + me.make + " (" + me.battery + " kWh)"

remember car = ElectricCar("Tesla", 2024, 75)
car.drive(150)
car.info()
car.charge()
car.drive(200)
car.info()

say "=== All done! ==="
