{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ILMA",
  "scopeName": "source.ilma",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#multi-word-keywords" },
    { "include": "#single-keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#blueprint-declaration" },
    { "include": "#recipe-declaration" },
    { "include": "#use-statement" },
    { "include": "#me-access" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.ilma",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ilma",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ilma",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.ilma",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.ilma",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.ilma",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.ilma",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "multi-word-keywords": {
      "patterns": [
        {
          "name": "keyword.control.give-back.ilma",
          "match": "\\bgive\\s+back\\b"
        },
        {
          "name": "keyword.control.for-each.ilma",
          "match": "\\bfor\\s+each\\b"
        },
        {
          "name": "keyword.control.keep-going-while.ilma",
          "match": "\\bkeep\\s+going\\s+while\\b"
        },
        {
          "name": "keyword.control.when-wrong.ilma",
          "match": "\\bwhen\\s+wrong\\b"
        },
        {
          "name": "keyword.operator.is-not.ilma",
          "match": "\\bis\\s+not\\b"
        },
        {
          "name": "keyword.control.otherwise-if.ilma",
          "match": "\\botherwise\\s+if\\b"
        },
        {
          "name": "keyword.control.comes-from.ilma",
          "match": "\\bcomes\\s+from\\b"
        },
        {
          "name": "variable.language.comes-from-parent.ilma",
          "match": "\\bcomes_from\\b"
        }
      ]
    },
    "single-keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.ilma",
          "match": "\\b(if|otherwise|repeat|try|in)\\b"
        },
        {
          "name": "keyword.other.say.ilma",
          "match": "\\b(say|shout)\\b"
        },
        {
          "name": "keyword.other.remember.ilma",
          "match": "\\bremember\\b"
        },
        {
          "name": "keyword.other.ask.ilma",
          "match": "\\bask\\b"
        },
        {
          "name": "keyword.other.recipe.ilma",
          "match": "\\brecipe\\b"
        },
        {
          "name": "keyword.other.blueprint.ilma",
          "match": "\\bblueprint\\b"
        },
        {
          "name": "keyword.other.create.ilma",
          "match": "\\bcreate\\b"
        },
        {
          "name": "keyword.other.use.ilma",
          "match": "\\buse\\b"
        },
        {
          "name": "keyword.operator.logical.ilma",
          "match": "\\b(and|or|not|is)\\b"
        },
        {
          "name": "keyword.other.collection.ilma",
          "match": "\\b(bag|notebook)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.ilma",
          "match": "\\b(whole|decimal|text|truth|anything)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.ilma",
          "match": "\\byes\\b"
        },
        {
          "name": "constant.language.boolean.false.ilma",
          "match": "\\bno\\b"
        },
        {
          "name": "constant.language.null.ilma",
          "match": "\\bempty\\b"
        }
      ]
    },
    "blueprint-declaration": {
      "patterns": [
        {
          "match": "\\b(blueprint)\\s+([A-Z][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.blueprint.ilma" },
            "2": { "name": "entity.name.type.class.ilma" }
          }
        }
      ]
    },
    "recipe-declaration": {
      "patterns": [
        {
          "match": "\\b(recipe)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.recipe.ilma" },
            "2": { "name": "entity.name.function.ilma" }
          }
        }
      ]
    },
    "use-statement": {
      "patterns": [
        {
          "match": "\\b(use)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.other.use.ilma" },
            "2": { "name": "entity.name.module.ilma" }
          }
        }
      ]
    },
    "me-access": {
      "patterns": [
        {
          "match": "\\b(me)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.language.this.ilma" },
            "2": { "name": "variable.other.property.ilma" }
          }
        },
        {
          "name": "variable.language.this.ilma",
          "match": "\\bme\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.ilma" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.ilma",
          "match": ">=|<=|>|<"
        },
        {
          "name": "keyword.operator.assignment.ilma",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.ilma",
          "match": "[+\\-*/%]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.ilma",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.ilma",
          "match": ","
        },
        {
          "name": "punctuation.bracket.round.open.ilma",
          "match": "\\("
        },
        {
          "name": "punctuation.bracket.round.close.ilma",
          "match": "\\)"
        },
        {
          "name": "punctuation.bracket.square.open.ilma",
          "match": "\\["
        },
        {
          "name": "punctuation.bracket.square.close.ilma",
          "match": "\\]"
        }
      ]
    }
  }
}
